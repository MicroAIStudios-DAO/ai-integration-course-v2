# Firebase Configuration (Required)
# Copy these from your Firebase project settings for the target environment.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Required - App Check + reCAPTCHA Enterprise (protects login, signup, checkout, lead capture)
# Project: ai-integra-course-v2 | Obtain from: Google Cloud Console > reCAPTCHA Enterprise
VITE_RECAPTCHA_ENTERPRISE_KEY=6LfhDcosAAAAAP6nU36DVwxoGBmjqJW5VWGy-dCa

# Optional - Stripe Configuration
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional - App Check Debug (development only)
# VITE_APPCHECK_DEBUG=true

# Optional - source maps (default off for security; set to "true" to enable for debugging)
# VITE_SOURCEMAP=true

# ─────────────────────────────────────────────────────────────────────────────
# AI Tutor v2.0 — Adaptive Learning Engine (Gemini 1.5 Pro)
# ─────────────────────────────────────────────────────────────────────────────
# Required for the v2 agentic tutor (set in Firebase Functions secrets)
# GEMINI_API_KEY=your_gemini_api_key

# Optional - Override the v2 tutor endpoint URL (defaults to production)
# VITE_TUTOR_V2_URL=https://us-central1-ai-integra-course-v2.cloudfunctions.net/tutorV2

